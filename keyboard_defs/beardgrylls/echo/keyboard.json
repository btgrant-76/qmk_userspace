{
    "keyboard_name": "echo",
    "bootloader": "stm32-dfu",
    "diode_direction": "COL2ROW",
    "features": {
        "bootmagic": true,
        "extrakey": true,
        "mousekey": true,
        "nkro": true,
	"no_startup_check": true
    },
    "matrix_pins": {
        "cols": ["B2", "B11", "B9", "A6", "A7", "B0"],
        "rows": ["B10", "A4", "A5", "B1"]
    },
    "split": {
        "enabled": true,
        "serial": {
          "driver": "usart",
          "pin": "A9"
        }
    },
    "processor": "STM32F072",
    "usb": {
        "device_version": "1.0.0",
        "pid": "0x0000",
        "vid": "0xCB10"
    },
    "manufacturer": "beardgrylls",
    "maintainer": "qmk",
    "layouts": {
        "LAYOUT": {
            "layout": [
                {"label": "Esc", "matrix": [0, 0], "x": 0, "y": 0},
                {"label": "Q", "matrix": [0, 1], "x": 1, "y": 0},
                {"label": "W", "matrix": [0, 2], "x": 2, "y": 0},
